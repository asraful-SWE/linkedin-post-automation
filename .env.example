# .env.example - Environment Variables Template

# ========================= TELEGRAM BOT ========================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Telegram user ID (get from @userinfobot)
TELEGRAM_ADMIN_ID=YOUR_USER_ID_HERE

# ====================== LINKEDIN CREDENTIALS ====================
LINKEDIN_ACCESS_TOKEN=YOUR_LINKEDIN_TOKEN_HERE
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_URN
LINKEDIN_PERSON_ID=YOUR_PERSON_ID
EMAIL_ADDRESS=your_email@example.com
EMAIL_PASSWORD=your_email_password

# ======================== OPENAI API KEY ========================
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY_HERE

# ======================== IMAGE CONFIGURATION ====================
# Optional - for image generation
# UNSPLASH_ACCESS_KEY=your_unsplash_key
# PEXELS_API_KEY=your_pexels_key

# ==================== POSTING SCHEDULE CONFIGURATION =============
# Maximum posts per day
MAX_POSTS_PER_DAY=2

# Minimum hours between posts
MIN_HOURS_BETWEEN_POSTS=4

# Test mode for rapid posting
TEST_MODE=false

# Mock mode - saves posts to database without actual LinkedIn publishing
MOCK_LINKEDIN_POSTING=false

# Timezone for scheduling
TIMEZONE=Asia/Dhaka

# Enable/disable automatic scheduling
AUTO_SCHEDULE_ENABLED=true

# ====================== APPLICATION CONFIGURATION ================
# Server host and port
HOST=0.0.0.0
PORT=8000

# Debug mode
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =================== NATURAL BEHAVIOR SETTINGS ====================
# Probability of skipping a scheduled post (0.0 to 1.0)
SKIP_PROBABILITY=0.15

# Enable natural behavior randomization
NATURAL_BEHAVIOR_ENABLED=true

# ========================== DATABASE =============================
DATABASE_PATH=linkedin_ai_poster.db

# ========================= API CONFIGURATION ====================
# Backend API URL
API_URL=http://localhost:8000
