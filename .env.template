# LinkedIn Auto Poster Configuration
# Copy this file to .env and fill in your actual values
# Updated: includes Intelligent Engines, Image APIs, Celery/Redis, A/B Testing

# === AI PROVIDER CONFIGURATION ===
# OpenAI API Key (required for post generation)
OPENAI_API_KEY=your_openai_api_key_here

# === LINKEDIN API CONFIGURATION ===
# LinkedIn API credentials (required for posting)
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_ID=your_linkedin_person_id

# === POSTING SCHEDULE CONFIGURATION ===
# Maximum posts per day
MAX_POSTS_PER_DAY=2

# Minimum hours between posts
MIN_HOURS_BETWEEN_POSTS=4

# Timezone for scheduling (use pytz timezone names)
TIMEZONE=Asia/Dhaka

# Enable/disable automatic scheduling (true/false)
AUTO_SCHEDULE_ENABLED=true

# === APPLICATION CONFIGURATION ===
# Server host and port
HOST=0.0.0.0
PORT=8000

# Debug mode (true/false)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# === NATURAL BEHAVIOR SETTINGS ===
# Probability of skipping a scheduled post (0.0 to 1.0)
SKIP_POST_PROBABILITY=0.15

# Probability of making a second post in a day (0.0 to 1.0)
DOUBLE_POST_PROBABILITY=0.05

# === DATABASE CONFIGURATION ===
# Database file path (SQLite)
DATABASE_PATH=linkedin_ai_poster.db

# === APPROVAL WORKFLOW CONFIGURATION ===
# Public base URL used in approval links sent by email
BASE_URL=http://localhost:8000

# Secret used to hash/validate one-time approval tokens
APPROVAL_SECRET=change-this-to-a-long-random-secret

# Approval token expiration window (in hours)
APPROVAL_TOKEN_EXPIRES_HOURS=24

# === EMAIL (SMTP) CONFIGURATION ===
# SMTP server settings for sending approval emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Backward-compatible aliases (optional):
# EMAIL_ADDRESS=your_email@example.com
# EMAIL_PASSWORD=your_app_password

# Optional HTTPS email provider fallback (recommended on platforms blocking SMTP ports)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# RESEND_FROM=onboarding@resend.dev

# Email sender and approver recipient
EMAIL_FROM=noreply@example.com
APPROVAL_EMAIL_TO=approver@example.com

# === SAFETY AND ANTI-BOT MEASURES ===
# Enable random delays between actions
RANDOM_DELAYS=true

# Enable content variation
CONTENT_VARIATION=true

# === MOCK / TEST MODE ===
# Set to true to simulate LinkedIn posts without actually publishing
MOCK_LINKEDIN_POSTING=false

# Set to true to run scheduler at accelerated intervals for testing
TEST_MODE=false

# === IMAGE AUTO-SELECTION (Unsplash / Pexels) ===
# Set to true to automatically attach a relevant image to generated posts
ENABLE_IMAGES=false

# Unsplash API access key — https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels API key — https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Maximum allowed image size in megabytes (LinkedIn limit: 5 MB)
IMAGE_MAX_SIZE_MB=5

# === INTELLIGENT CONTENT ENGINE ===
# Minimum quality score (0–10) a generated post must achieve before queuing
CONTENT_SCORE_THRESHOLD=6.0

# How many times the LLM may regenerate a post that scored below the threshold
MAX_REGENERATION_ATTEMPTS=3

# === ADMIN API ===
# Static API key required for all /admin/* endpoints (X-Admin-Key header)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=change-this-to-a-long-random-admin-key

# === CELERY / REDIS (Background Task Queue) ===
# Set USE_CELERY=true only when a Redis broker is running
USE_CELERY=false

# Redis broker URL (used by Celery workers)
CELERY_BROKER_URL=redis://localhost:6379/0

# Redis result backend URL
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === OBSERVABILITY ===
# Emit structured JSON log lines instead of plain text (recommended in production)
ENABLE_JSON_LOGS=false
